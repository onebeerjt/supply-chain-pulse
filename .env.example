# AISStream key (required for live vessel tracking)
# Get a key at https://aisstream.io/
AISSTREAM_API_KEY=

# Optional weather provider key. Uses sample disruption weather alerts when missing.
OPENWEATHER_API_KEY=

# Optional LLM provider keys for AI Daily Brief generation.
# If neither key is set, deterministic template briefs are used.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional map token. Current map defaults to Leaflet + open dark tiles.
NEXT_PUBLIC_MAPBOX_TOKEN=
