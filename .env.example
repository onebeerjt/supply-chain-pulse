# Optional map token. App falls back to Leaflet + open dark tiles if missing.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional weather provider key. Uses sample disruption weather alerts when missing.
OPENWEATHER_API_KEY=

# Optional LLM provider keys for AI Daily Brief generation.
# If neither key is set, deterministic template briefs are used.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional logistics feed keys.
# If missing, seeded realistic sample traffic/congestion data is used.
VESSEL_API_KEY=
PORT_DATA_API_KEY=
